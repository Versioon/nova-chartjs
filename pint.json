{
  "preset": "laravel",
  "rules": {
    "not_operator_with_successor_space": false,
    "class_attributes_separation": false,
    "concat_space": {
      "spacing": "one"
    },
    "control_structure_braces": false,
    "ordered_imports": {
      "sort_algorithm": "length"
    },
    "fully_qualified_strict_types": false
  }
}
